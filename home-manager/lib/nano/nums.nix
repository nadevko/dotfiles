{
  fill = ''
    Set the target width for justifying and automatic hard-wrapping at this
    number of columns. If the value is 0 or less, wrapping will occur at the
    width of the screen minus number columns, allowing the wrap point to vary
    along with the width of the screen if the screen is resized. The default
    value is -8.
  '';
  guidestripe = ''
    Draw a vertical stripe at the given column, to help judge the width of the
    text. (The color of the stripe can be changed with set stripecolor).
  '';
  tabsize = ''
    Use a tab size of number columns. The value of number must be greater than
    0. The default value is 8.
  '';
}
